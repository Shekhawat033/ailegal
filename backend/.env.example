# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Default SQLite (delete backend/ailegal.db after schema changes)
# DATABASE_URL=sqlite:///./ailegal.db

# Production Postgres (docker compose):
# DATABASE_URL=postgresql+psycopg://ailegal:ailegal@localhost:5432/ailegal

# CORS_ORIGINS=http://localhost:5173
# For Vercel previews (any *.vercel.app):
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app
# Or allow all (dev only):
# CORS_ORIGINS=*
